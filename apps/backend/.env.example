DATABASE_URL=postgres://chat:chat@localhost:5432/chat?sslmode=disable
REDIS_ADDR=localhost:6379
PORT=8080

# Claude API — ใช้ Anthropic ตรง ๆ:
ANTHROPIC_API_KEY=sk-ant-...
# (ANTHROPIC_BASE_URL / ANTHROPIC_MODEL ไม่ต้องตั้ง — default = api.anthropic.com + claude-opus-4-8)

# หรือใช้ผ่าน DeepInfra (Anthropic-compatible) ด้วย DeepInfra key:
# ANTHROPIC_API_KEY=<deepinfra-token>
# ANTHROPIC_BASE_URL=https://api.deepinfra.com/anthropic
# ANTHROPIC_MODEL=anthropic/claude-opus-4-8
